# Database Configuration
DATABASE_URL=postgresql://username:password@localhost:5432/organ_donation
DB_ECHO=False

# Flask Configuration
FLASK_ENV=development
FLASK_DEBUG=True
SECRET_KEY=your-secret-key-here-change-in-production

# Security & Encryption
ENCRYPTION_KEY=your-encryption-key-here
JWT_SECRET=your-jwt-secret-here
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# Region Configuration
DEFAULT_REGION=Bangalore
DEFAULT_LATITUDE=12.9716
DEFAULT_LONGITUDE=77.5946
DEFAULT_SEARCH_RADIUS_KM=10
MAX_SEARCH_RADIUS_KM=500

# Transport & Routing
ENABLE_GREEN_CORRIDOR=True
TRAFFIC_DEPT_API_URL=https://api.traffic.gov.in/green-corridor
TRAFFIC_DEPT_API_KEY=your-api-key-here

# Notifications
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@example.com
SMTP_PASSWORD=your-app-password
NOTIFICATION_FROM_EMAIL=noreply@organ-donation.org

# Matching Algorithm Parameters
MIN_SURVIVAL_PROBABILITY=0.5
URGENCY_WEIGHT=0.4
COMPATIBILITY_WEIGHT=0.35
PROXIMITY_WEIGHT=0.25

# Logging & Compliance
LOG_LEVEL=INFO
ENABLE_AUDIT_LOGS=True
LOG_FILE_PATH=logs/application.log
AUDIT_LOG_PATH=logs/audit.log

# API Rate Limiting
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_HOUR=1000
